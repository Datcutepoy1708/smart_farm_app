{
  "expo": {
    "name": "Smart Farm",
    "slug": "smart-farm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartfarm",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A2D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Cho phép Smart Farm nhận dạng giọng nói để hỗ trợ nông dân",
        "NSMicrophoneUsageDescription": "Cho phép Smart Farm sử dụng microphone để nhập ghi chú bằng giọng nói"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2D6A2D"
      },
      "package": "com.smartfarm.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#2D6A2D"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cho phép Smart Farm sử dụng microphone để nhập ghi chú bằng giọng nói",
          "speechRecognitionPermission": "Cho phép Smart Farm nhận dạng giọng nói để hỗ trợ nông dân"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8683fb24-8c53-4c6e-a44f-2ee1882e49ce"
      }
    }
  }
}
